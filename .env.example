# CHAGEEPT Environment Variables
# Copy this file to .env and fill in your values

# Google AI Studio API key for LLM (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_key_here

# Tavily API key for web search fallback (get from https://tavily.com)
# Optional: only used when the knowledge base has no good answer for a CHAGEE-related query.
TAVILY_API_KEY=your_key_here
